# Rafiki environment contract for agents and local operators.
# Application loaders read only the repository-root .env file.
# Varlock imports below resolve user-managed values for agent commands; they do
# not add application-side .env.local loading.
# @import(~/.agents/env/values/.env.shared.local, pick=[GOOGLE_API_KEY, OPENAI_API_KEY, FLOYO_KEY, REPLICATE_API_TOKEN, NOTION_API_KEY], allowMissing=true)
# @import(~/.agents/env/values/.env.rafiki.local, pick=[GOOGLE_API_KEY, OPENAI_API_KEY, FLOYO_KEY, REPLICATE_API_TOKEN, NOTION_API_KEY], allowMissing=true)
# @defaultRequired=false
# @defaultSensitive=false
# ---

# Gemini image generation API key.
# @sensitive
# @docs(https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Legacy Gemini readiness alias; generation uses GOOGLE_API_KEY.
# @sensitive
GEMINI_API_KEY=

# OpenAI image generation API key.
# @sensitive
# @docs(https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Optional Chrome/Chromium executable for HTML-to-PNG rendering.
# @public
# @docs(docs/CHROME-PUPPETEER.md)
PUPPETEER_EXECUTABLE_PATH=

# Optional Chrome/Chromium executable aliases used by common CI images.
# @public
# @docs(docs/CHROME-PUPPETEER.md)
CHROME_PATH=

# @public
# @docs(docs/CHROME-PUPPETEER.md)
GOOGLE_CHROME_BIN=

# Optional Python executable override used by the doctor command.
# @public
# @docs(docs/DOCTOR.md)
RAFIKI_DOCTOR_PYTHON=

# Optional artifact directory used by the portal E2E smoke.
# @public
# @docs(docs/PORTAL-COMMAND-CENTER.md)
RAFIKI_E2E_ARTIFACT_DIR=

# Optional HTTP Basic auth username for the local portal.
# @public
PORTAL_USERNAME=

# Optional HTTP Basic auth password for the local portal.
# @sensitive
PORTAL_PASSWORD=

# Floyo hosted-ComfyUI API key for --execute video workflows.
# @sensitive
# @docs(docs/FLOYO.md)
FLOYO_KEY=

# Replicate API token for --execute video workflows.
# @sensitive
# @docs(docs/FLOYO.md)
REPLICATE_API_TOKEN=

# Notion internal integration token for gallery exports.
# @sensitive
# @docs(docs/NOTION-EXPORT.md)
NOTION_API_KEY=

# Notion gallery database ID for exports.
# @sensitive
# @docs(docs/NOTION-EXPORT.md)
NOTION_DATABASE_ID=

# Non-secret sentinel used to verify Varlock child-process injection.
# @public
RAFIKI_VARLOCK_SMOKE=ready
