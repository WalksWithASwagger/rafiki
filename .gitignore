# Environment variables (contains API keys - NEVER commit)
.env

# macOS / local scratch
.DS_Store
/rafiki/
/animation-accelerator

# One-off local renders (regenerable)
output.png
test-image.png
output/

# Generated outputs (large files, regenerable)
outputs/

# Local thumbnail/cache artifacts (regenerable)
.rafiki-cache/
**/.rafiki-cache/

# Notion exporter idempotency log (per-project, local state)
output/*/.notion-exported.json

# Knowledge-base mirror artifacts (large copies; regenerable)
assets/kb-import/mirror/
assets/kb-import/prompt-stashes/

# Node modules
node_modules/

# Usage tracking (local data)
data/usage-log.json
data/billing-imports.json

# Asset registry — local cache, regenerable via `generate.py registry index`
data/asset-registry.json
data/asset-registry.csv

# Multimedia registry, local jobs, and review sidecars
data/media-registry.json
data/media-registry.csv
data/jobs/
data/video-selections.json

# Local Python environment (PEP 668–safe installs)
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Claude Code runtime files
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/worktrees/

# Local scheduled regen config (template: config/scheduled-regen.json.example)
config/scheduled-regen.json

# Local external-project registry override (template: config/extra-outputs.json.example)
config/extra-outputs.local.json

# Local loose-image import map (run-wrapper sources for non-standard outputs)
config/loose-imports.local.json

# Local multimedia roots (template: config/media-roots.json.example)
config/media-roots.local.json

# Local package artifacts
*.tgz
