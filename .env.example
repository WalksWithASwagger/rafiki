# Copy to .env in this directory (same folder as index.js). Never commit .env.

# Required for Gemini models (gemini-2.5-flash-image, gemini-3-pro-image-preview)
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Required for OpenAI models (gpt-image-2, gpt-image-1, dall-e-3)
OPENAI_API_KEY=

# Optional: Chrome/Chromium for `npx rafiki --render` (see docs/CHROME-PUPPETEER.md)
# PUPPETEER_EXECUTABLE_PATH=

# Optional: HTTP Basic auth for `python generate.py serve`.
# Only required when sharing the portal beyond localhost (e.g. with --public).
# When BOTH are set, every request must present a matching Authorization header.
# Recommended: PORTAL_PASSWORD=$(openssl rand -hex 16)
# PORTAL_USERNAME=
# PORTAL_PASSWORD=

# Optional: Floyo (flowyo.ai) hosted-ComfyUI video (`generate.py floyo generate --execute`)
# Get a key at https://flowyo.ai
# FLOYO_KEY=

# Optional: Replicate-backed video workflows (`generate.py video ... --execute`)
# REPLICATE_API_TOKEN=

# Optional: Notion gallery export (`generate.py notion-export <project>`)
# Create an internal integration at https://www.notion.so/my-integrations
# Then share the target database with that integration. See docs/NOTION-EXPORT.md.
# NOTION_API_KEY=
# NOTION_DATABASE_ID=
