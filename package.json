{
  "name": "rafiki",
  "version": "1.1.0",
  "description": "Local-first AI image generation and review workflow with a CLI, portal, and HTML-to-image rendering",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/WalksWithASwagger/rafiki.git"
  },
  "bugs": {
    "url": "https://github.com/WalksWithASwagger/rafiki/issues"
  },
  "homepage": "https://github.com/WalksWithASwagger/rafiki#readme",
  "bin": {
    "rafiki": "./index.js",
    "image-gen": "./index.js"
  },
  "scripts": {
    "generate": "node index.js",
    "render": "node index.js --render",
    "doctor": "node index.js --doctor",
    "test": "node scripts/run-pytest.js",
    "test:python": "node scripts/run-pytest.js",
    "pack:check": "npm pack --dry-run"
  },
  "files": [
    "index.js",
    "generate.py",
    "mcp_server.py",
    "lib/**/*.py",
    "styles/**/*.md",
    "styles/styles.yaml",
    "config/extra-outputs.json",
    "config/extra-outputs.json.example",
    "config/scheduled-regen.json.example",
    ".env.example",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "requirements.txt",
    "requirements-dev.txt",
    "docs/ASSET-REGISTRY.md",
    "docs/CHROME-PUPPETEER.md",
    "docs/FOLDER-LAYOUT.md",
    "docs/DELIVERY-PIPELINE.md",
    "docs/MCP.md",
    "docs/PUBLIC-RELEASE-PLAN.md",
    "docs/ROADMAP.md",
    "docs/SCOPE.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "puppeteer": "^24.0.0",
    "sharp": "^0.34.0"
  },
  "keywords": [
    "rafiki",
    "image-generation",
    "gemini",
    "openai",
    "prompt-engineering",
    "creative-tools",
    "puppeteer",
    "html-to-image"
  ],
  "author": "Rafiki contributors",
  "license": "MIT"
}
