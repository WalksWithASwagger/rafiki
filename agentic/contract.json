{
  "version": 2,
  "repo": {
    "owner": "WalksWithASwagger",
    "name": "rafiki",
    "linear_team": "Bc-ai",
    "linear_project": "Rafiki Roadmap Delivery",
    "canonical_local_root": "/Users/kk/Code/rafiki",
    "non_canonical_local_roots": []
  },
  "labels": {
    "ready": "agent:ready",
    "ready_aliases": [
      "auto-implement",
      "autonomous"
    ],
    "review_ready": "review-ready",
    "stop": [
      "needs-human",
      "blocked",
      "in-progress"
    ]
  },
  "limits": {
    "max_changed_files": 20,
    "max_changed_lines": 500
  },
  "branch_template": "codex/{linear_key_or_issue}-{slug}",
  "mirror_policy": "active_delivery_only",
  "pr_requirements": {
    "require_issue_link": true,
    "issue_link_verbs": [
      "Closes",
      "Refs"
    ],
    "require_linear_key_when_present": true,
    "branch_prefix": "codex/",
    "github_only_issue_prefix": "issue-",
    "body_linear_prefix": "Linear:"
  },
  "linear_sync": {
    "enabled": true,
    "api_token_env": "LINEAR_API_KEY",
    "comment_backfill": true,
    "active_project_policy": "active_delivery_only",
    "status_mapping": {
      "issue-in-progress": "In Progress",
      "pr-open": "In Review",
      "pr-merged": "Done"
    }
  },
  "default_triage": {
    "baseline_labels": [
      "agent:ready",
      "in-progress",
      "review-ready",
      "needs-human",
      "blocked"
    ],
    "assignee_policy": "leave-unassigned",
    "project_policy": "repo-default",
    "milestone_policy": "project-default"
  },
  "provider": {
    "default": "noop",
    "allowed": [
      "noop",
      "command"
    ],
    "command_env": "AGENTIC_PROVIDER_COMMAND"
  },
  "verification": {
    "commands": [
      "npm test",
      "npm run pack:check",
      "npm run doctor"
    ]
  },
  "issue_quality": {
    "required_sections": [
      "Context",
      "Acceptance Criteria",
      "Tests/Evals",
      "Verification",
      "Agent Instructions",
      "Out of Scope"
    ],
    "required_ready_labels": [
      "agent:ready",
      "auto-implement",
      "autonomous"
    ]
  }
}
